datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum LocaleCode {
  nl
  en
  es
  pap
}

enum PatientEventType {
  APPOINTMENT_REQUEST
  CONTACT
  NOTE
}

enum PatientEventStatus {
  OPEN
  RESOLVED
}

enum AppointmentRequestStatus {
  UNSCHEDULED
  SCHEDULED
  CANCELLED
}

enum AppointmentReason {
  CHECKUP
  CLEANING
  FILLING
  EXTRACTION
  ROOT_CANAL
  EMERGENCY
}

enum AppointmentContactChannel {
  PHONE
  MAIL
  WHATSAPP
  FRONT_DESK
}

enum AppointmentFollowUpOutcome {
  WHATSAPP_SENT
  CALLED_NO_ANSWER
  CALLED_APPOINTMENT_MADE
  WHATSAPP_CONFIRMED
  DECLINED_OFFER
}

enum StaffRole {
  DENTIST
  HYGIENIST
  SUPPORT
  DENTAL_ASSISTANT
}

/// Stores a single submitted intake form and associated metadata.
model IntakeSubmission {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  fullName     String
  dob          DateTime
  phone        String?
  email        String?
  residentType String
  address      String?
  country      String?

  medications       Json
  allergies         Json
  conditions        Json
  hadComplications  Boolean @default(false)
  complicationsNote String?

  locale          String
  marketingOptIn  Boolean @default(false)
  privacyAccepted Boolean
  userAgent       String?
  ipInet          String?

  encBlob Bytes?

  // Encryption metadata for rotation and audit
  encKeyId String? // identifier for the key used to encrypt encBlob
  encAlg   String? // e.g., 'AES-256-GCM'

  // Spam classification flag
  isSpam Boolean @default(false)

  // Optional linkage to core Patient (for cross-module use)
  patient   Patient? @relation(fields: [patientId], references: [id])
  patientId String?

  @@index([createdAt])
  @@index([fullName])
  @@index([email])
  @@index([phone])
}

/// Admin users for protected back office access.
model AdminUser {
  id             String   @id @default(uuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  username       String   @unique
  passwordHash   String   // scrypt hash string: scrypt$N$r$p$saltB64$hashB64

  lastLoginAt    DateTime?
  failedAttempts Int      @default(0)
  lockedUntil    DateTime?
}

/// Minimal audit trail for admin actions involving sensitive data.
model AdminAuditLog {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now())

  adminId    String
  action     String   // e.g., 'intake.decrypt', 'intake.delete'
  subjectId  String   // e.g., IntakeSubmission.id
  ipInet     String?
  userAgent  String?

  @@index([createdAt])
  @@index([adminId, createdAt])
}

/// Core domain models (per-tenant DB)
model Patient {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Minimal identifying fields; extend as needed by modules
  firstName String
  lastName  String
  dob       DateTime?
  email     String?
  phone     String?
  preferredLocale LocaleCode?

  intakeSubmissions IntakeSubmission[]
  events            PatientEvent[]
  appointmentRequests AppointmentRequest[]

  @@index([lastName, firstName])
  @@index([email])
  @@index([phone])
}

model PatientEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient   Patient  @relation(fields: [patientId], references: [id])
  patientId String
  occurredAt DateTime
  type      PatientEventType
  status    PatientEventStatus @default(OPEN)
  summary   String?
  payload   Json?
  createdBy StaffMember? @relation("StaffCreatedEvents", fields: [createdByStaffId], references: [id])
  createdByStaffId String?

  appointmentRequest AppointmentRequest? @relation("AppointmentRequestEvent")
  followUps         AppointmentRequestFollowUp[] @relation("FollowUpEvent")
  staffInvolvements StaffEventInvolvement[]

  @@index([patientId, occurredAt])
  @@index([type, occurredAt])
}

model AppointmentRequest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event   PatientEvent @relation("AppointmentRequestEvent", fields: [eventId], references: [id])
  eventId String       @unique

  patient   Patient @relation(fields: [patientId], references: [id])
  patientId String

  status             AppointmentRequestStatus @default(UNSCHEDULED)
  reasons            AppointmentReason[]
  plannedDurationMinutes Int @default(30)
  isEmergency        Boolean @default(false)
  basePriority       Int     @default(0)
  triageScore        Int     @default(0)
  declinePenalty     Int     @default(0)
  effectivePriority  Int     @default(0)
  triageInputs       Json?
  preferredProviderIds String[] @default([])
  availabilityMatrix Json?
  notes              String?
  lastContactAt      DateTime?
  nextActionAt       DateTime?
  scheduledStart     DateTime?
  scheduledEnd       DateTime?
  preferredLocale    LocaleCode @default(en)

  createdBy       StaffMember? @relation("StaffCreatedAppointments", fields: [createdByStaffId], references: [id])
  createdByStaffId String?

  followUps AppointmentRequestFollowUp[]

  @@index([patientId, status])
  @@index([status, effectivePriority])
  @@index([isEmergency, effectivePriority])
  @@index([nextActionAt])
}

model AppointmentRequestFollowUp {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  request   AppointmentRequest @relation(fields: [requestId], references: [id])
  requestId String
  event     PatientEvent?       @relation("FollowUpEvent", fields: [eventId], references: [id])
  eventId   String?

  occurredAt DateTime
  channel    AppointmentContactChannel
  outcome    AppointmentFollowUpOutcome
  notes      String?
  affectsPriority Boolean @default(false)
  priorityDelta   Int     @default(0)

  staff   StaffMember? @relation("StaffFollowUps", fields: [staffId], references: [id])
  staffId String?

  @@index([requestId, occurredAt])
}

model StaffMember {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firstName   String
  lastName    String
  phone       String?
  email       String?
  address     String?
  bankAccount String?
  role        StaffRole
  active      Boolean @default(true)

  createdEvents   PatientEvent[]            @relation("StaffCreatedEvents")
  appointmentRequestsCreated AppointmentRequest[] @relation("StaffCreatedAppointments")
  followUps AppointmentRequestFollowUp[]    @relation("StaffFollowUps")
  involvements StaffEventInvolvement[]
}

model StaffEventInvolvement {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  event   PatientEvent @relation(fields: [eventId], references: [id])
  eventId String

  staff   StaffMember @relation(fields: [staffId], references: [id])
  staffId String

  role StaffRole

  @@index([eventId])
  @@index([staffId, createdAt])
}

model OutboxEvent {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  topic      String   // e.g., 'intake.submitted'
  payload    Json
  processedAt DateTime?

  @@index([createdAt])
  @@index([topic, createdAt])
}

/// Control plane models for multi-tenancy
model Tenant {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  slug      String   @unique
  name      String

  hosts     TenantHost[]
  branding  Branding?
  secrets   TenantSecret?
}

model TenantHost {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  host      String   @unique
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String
}

model Branding {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String   @unique

  logoUrl   String?
  primary   String?
  secondary String?
}

model TenantSecret {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  tenantId         String   @unique
  dbUrlCiphertext  String
  encKeyCiphertext String
  kmsKeyId         String?
}

model SuperAdminUser {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  username       String   @unique
  passwordHash   String
  lastLoginAt    DateTime?
  failedAttempts Int      @default(0)
  lockedUntil    DateTime?
}
